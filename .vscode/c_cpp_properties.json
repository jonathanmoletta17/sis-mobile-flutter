            "name": "Win32, linux, macOS",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/linux/flutter/ephemeral", 
                "${workspaceFolder}/macos/Flutter/ephemeral", 
                "${workspaceFolder}/windows/flutter/ephemeral"
            ],
            "defines": [
