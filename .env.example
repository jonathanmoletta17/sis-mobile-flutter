# Chave legada ainda suportada. Prefira as chaves especificas por app.
GLPI_BASE_URL=http://cau.ppiratini.intra.rs.gov.br/sis/apirest.php

# Linha SIS.
SIS_GLPI_BASE_URL=http://cau.ppiratini.intra.rs.gov.br/sis/apirest.php
GLPI_DEBUG_LOGS=false

# Conta de teste dedicada (QA/bot) para validacao mutavel controlada.
# Usada APENAS pelo harness de validacao (tool/validation). Nunca usar conta de
# usuario real. Ver CLAUDE.md > Regras locais. Para simular papeis tecnicos a
# conta precisa dos perfis/entidades atribuidos no GLPI (Solicitante,
# Tecnico/Conservacao, Tecnico/Manutencao, ...).
SIS_TEST_USER=
SIS_TEST_PASSWORD=
# Opcional: credenciais administrativas de teste, exigidas SOMENTE quando o
# harness precisar ajustar (de forma reversivel) as atribuicoes da propria conta
# de teste. Deixe vazio para manter o harness sem poder administrativo.
SIS_TEST_ADMIN_USER=
SIS_TEST_ADMIN_PASSWORD=
# Alvos do harness de validacao mutavel (test/validation): categoria que dispara
# a RuleTicket de atribuicao e entidade do requerente de teste.
SIS_TEST_CATEGORY_ID=
SIS_TEST_ENTITY_ID=
# Flags de execucao do harness (normalmente passadas inline no comando, nao aqui):
#   SIS_VALIDATION_ENABLE=true  -> habilita acesso ao GLPI real (read-only inclusive)
#   SIS_VALIDATION_APPLY=true   -> habilita a criacao/fechamento do ticket de teste

# Linha DTIC. Para uso fora do dominio, apontar para o Worker DTIC.
DTIC_GLPI_BASE_URL=https://dtic-glpi.<conta>.workers.dev/glpi/apirest.php
DTIC_ENABLE_TICKET_ACTIONS=false
DTIC_ENABLE_FORM_SUBMISSION=false

# Checklists SIS (FormCreator). Read-only por padrao; ambas as flags desligadas.
# SIS_ENABLE_CHECKLISTS_SUBMISSION so faz efeito junto do flag de Worker
# ALLOW_FORMCREATOR_SUBMISSION=true e em ambiente autorizado (sandbox/homologacao).
SIS_CHECKLISTS_METADATA_URL=
SIS_ENABLE_CHECKLISTS_PREVIEW=false
SIS_ENABLE_CHECKLISTS_SUBMISSION=false
# Prefixo opcional para tickets de checklist criados em validacao mutavel.
# Em producao, manter vazio.
SIS_CHECKLIST_TICKET_NAME_PREFIX=
